NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=*

DATABASE_URL=postgresql://buzzchat:buzzchat@localhost:5433/buzzchat?schema=public
REDIS_URL=redis://localhost:6380

# Put the Firebase Admin service account JSON at backend/serviceAccountKey.json.
# Alternative: set FIREBASE_SERVICE_ACCOUNT_PATH to an absolute JSON path.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Use only for local backend smoke tests before Firebase Admin credentials are ready.
ALLOW_UNVERIFIED_AUTH=false
